{
  "name": "@repowise-dev/ui",
  "version": "0.1.0",
  "description": "Shared visualization components for the Repowise dashboard (packages/web) and downstream consumers. Domains: graph, git, dead-code, decisions, docs, symbols, coverage, wiki, chat, dashboard, workspace, jobs, blast-radius, plus shared primitives and hooks.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "styles",
    "scripts"
  ],
  "sideEffects": [
    "./styles/globals.css",
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./styles/globals.css",
    "./brand": "./src/brand.ts",
    "./graph": "./src/graph/index.ts",
    "./graph/context": "./src/graph/context.ts",
    "./graph/elk-layout": "./src/graph/elk-layout.ts",
    "./graph/use-elk-layout": "./src/graph/use-elk-layout.ts",
    "./graph/nodes/*": "./src/graph/nodes/*.tsx",
    "./graph/edges/*": "./src/graph/edges/*.tsx",
    "./graph/*": "./src/graph/*.tsx",
    "./git": "./src/git/index.ts",
    "./git/*": "./src/git/*.tsx",
    "./commits": "./src/commits/index.ts",
    "./commits/*": "./src/commits/*.tsx",
    "./dead-code": "./src/dead-code/index.ts",
    "./dead-code/*": "./src/dead-code/*.tsx",
    "./health": "./src/health/index.ts",
    "./health/*": "./src/health/*.tsx",
    "./coupling": "./src/coupling/index.ts",
    "./coupling/*": "./src/coupling/*.tsx",
    "./decisions": "./src/decisions/index.ts",
    "./decisions/*": "./src/decisions/*.tsx",
    "./files": "./src/files/index.ts",
    "./files/*": "./src/files/*.tsx",
    "./docs": "./src/docs/index.ts",
    "./docs/doc-nav": "./src/docs/doc-nav.ts",
    "./docs/reader-persona": "./src/docs/reader-persona.ts",
    "./docs/*": "./src/docs/*.tsx",
    "./symbols": "./src/symbols/index.ts",
    "./symbols/*": "./src/symbols/*.tsx",
    "./owners": "./src/owners/index.ts",
    "./owners/*": "./src/owners/*.tsx",
    "./modules": "./src/modules/index.ts",
    "./modules/*": "./src/modules/*.tsx",
    "./coverage": "./src/coverage/index.ts",
    "./coverage/*": "./src/coverage/*.tsx",
    "./wiki": "./src/wiki/index.ts",
    "./wiki/wiki-mdx-preprocess": "./src/wiki/wiki-mdx-preprocess.ts",
    "./wiki/wiki-links-types": "./src/wiki/wiki-links-types.ts",
    "./wiki/*": "./src/wiki/*.tsx",
    "./chat": "./src/chat/index.ts",
    "./chat/*": "./src/chat/*.tsx",
    "./dashboard": "./src/dashboard/index.ts",
    "./dashboard/*": "./src/dashboard/*.tsx",
    "./stats": "./src/stats/index.ts",
    "./stats/*": "./src/stats/*.tsx",
    "./workspace": "./src/workspace/index.ts",
    "./workspace/system-map": "./src/workspace/system-map/index.ts",
    "./workspace/dsm": "./src/workspace/dsm/index.ts",
    "./workspace/*": "./src/workspace/*.tsx",
    "./jobs": "./src/jobs/index.ts",
    "./jobs/*": "./src/jobs/*.tsx",
    "./blast-radius": "./src/blast-radius/index.ts",
    "./blast-radius/*": "./src/blast-radius/*.tsx",
    "./c4": "./src/c4/index.ts",
    "./c4/export": "./src/c4/export/index.ts",
    "./c4/*": "./src/c4/*.tsx",
    "./dependencies": "./src/dependencies/index.ts",
    "./dependencies/*": "./src/dependencies/*.tsx",
    "./costs": "./src/costs/index.ts",
    "./costs/*": "./src/costs/*.tsx",
    "./security": "./src/security/index.ts",
    "./security/*": "./src/security/*.tsx",
    "./onboarding": "./src/onboarding/index.ts",
    "./onboarding/*": "./src/onboarding/*.tsx",
    "./settings": "./src/settings/index.ts",
    "./settings/*": "./src/settings/*.tsx",
    "./shared": "./src/shared/index.ts",
    "./shared/entity": "./src/shared/entity/index.ts",
    "./shared/responsive-table": "./src/shared/responsive-table/index.ts",
    "./shared/context-drawer": "./src/shared/context-drawer/index.ts",
    "./shared/file-card": "./src/shared/file-card/index.ts",
    "./shared/related": "./src/shared/related/index.ts",
    "./shared/*": "./src/shared/*.tsx",
    "./hooks": "./src/hooks/index.ts",
    "./ui": "./src/ui/index.ts",
    "./ui/*": "./src/ui/*.tsx",
    "./lib/cn": "./src/lib/cn.ts",
    "./lib/confidence": "./src/lib/confidence.ts",
    "./lib/format": "./src/lib/format.ts",
    "./lib/page-types": "./src/lib/page-types.ts"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "gates": "bash ./scripts/ui-gates.sh"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.19.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@repowise-dev/types": "*",
    "@sigma/edge-curve": "^3.1.0",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "elkjs": "^0.11.1",
    "framer-motion": "^11.11.0",
    "fuse.js": "^7.0.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-types": "^0.24.8",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.15.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.0",
    "sigma": "^3.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.4.0"
  },
  "peerDependencies": {
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "bin": {
    "repowise-ui-gates": "./scripts/ui-gates.sh",
    "repowise-ui-no-raw-hex": "./scripts/no-raw-hex-check.sh",
    "repowise-ui-contrast-check": "./scripts/contrast-check.py"
  }
}
