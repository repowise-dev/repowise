{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "@repowise-dev/types": ["../types/src/index.ts"],
      "@repowise-dev/types/*": ["../types/src/*"],
      "@repowise-dev/ui": ["../ui/src/index.ts"],
      "@repowise-dev/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts"]
}
