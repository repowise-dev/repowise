{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "types": ["node", "vscode", "mocha"],
    "paths": {
      "@repowise-dev/api-client": ["../api-client/src/index.ts"],
      "@repowise-dev/api-client/*": ["../api-client/src/*"],
      "@repowise-dev/types": ["../types/src/index.ts"],
      "@repowise-dev/types/*": ["../types/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
